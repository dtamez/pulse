ENVIRONMENT=development
TESTING=0
SQL_ECHO=1

ASYNC_DATABASE_SHARD0_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
ASYNC_DATABASE_SHARD1_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5433/DBNAME
SYNC_DATABASE_SHARD0_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
SYNC_DATABASE_SHARD1_URL=postgresql+psycopg://USER:PASSWORD@HOST:5433/DBNAME
REDIS_URL=redis://HOST:6379/0
CELERY_RESULT_BACKEND=redis://HOST:6379/1
